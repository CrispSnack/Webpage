# ─────────────────────────────────────────────────────────────────────────────
# Crispy N Snacky — Environment Variables Reference
# Copy to .env and fill in all values. NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
# Postgres connection string (Neon, Supabase, Railway, or local Docker)
DATABASE_URL=postgresql://user:password@host:5432/crispynsnacky

# ── Session ───────────────────────────────────────────────────────────────────
# At least 64 random characters. Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=replace_with_64_char_random_hex_string

# ── API Server ────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development           # development | production

# ── Storefront (Vite) ─────────────────────────────────────────────────────────
# Exposed to the browser — safe values only, no secrets
VITE_API_BASE_URL=http://localhost:8080   # dev; set to prod API URL in production

# ── Admin Dashboard (Vite) ────────────────────────────────────────────────────
VITE_ADMIN_API_BASE_URL=http://localhost:8080

# ── Payments (Razorpay) ───────────────────────────────────────────────────────
# Get from https://dashboard.razorpay.com/app/keys
# Key ID is safe to expose to the browser; Key Secret is SERVER-SIDE ONLY
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret   # ← NEVER expose to client

# ── Webhooks ─────────────────────────────────────────────────────────────────
# Razorpay webhook secret (set in Razorpay Dashboard → Webhooks)
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ── Email (optional — for order confirmations) ────────────────────────────────
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=noreply@crispynsnacky.in
# SMTP_PASS=your_smtp_password
# FROM_EMAIL="Crispy N Snacky <noreply@crispynsnacky.in>"

# ── GST / Business ────────────────────────────────────────────────────────────
# Your registered GSTIN (shown on invoices)
# BUSINESS_GSTIN=33XXXXXXXXX1Z5

# ── Analytics (optional) ─────────────────────────────────────────────────────
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# VITE_CLARITY_PROJECT_ID=xxxxxxxxxxxx
